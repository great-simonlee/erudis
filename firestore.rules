rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function postData(postId) {
      return get(/databases/$(database)/documents/posts/$(postId)).data;
    }

    function postExists(postId) {
      return exists(/databases/$(database)/documents/posts/$(postId));
    }

    function canViewPost(postId) {
      return isSignedIn() && postExists(postId) && (
        request.auth.uid == postData(postId).authorId ||
        postData(postId).visibility == 'public' ||
        (
          postData(postId).visibility == 'members_only' &&
          postData(postId).labId != null &&
          exists(/databases/$(database)/documents/labs/$(postData(postId).labId)) &&
          request.auth.uid in get(/databases/$(database)/documents/labs/$(postData(postId).labId)).data.memberIds
        )
      );
    }

    function postEngagementOnly() {
      let d = request.resource.data.diff(resource.data).affectedKeys();
      return d.hasOnly(['resonateCount'])
        || d.hasOnly(['resonateCount', 'updatedAt'])
        || d.hasOnly(['commentCount'])
        || d.hasOnly(['commentCount', 'updatedAt'])
        || d.hasOnly(['resonateCount', 'commentCount', 'updatedAt']);
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && request.auth.uid == userId;
      allow delete: if false;
    }

    match /users/{userId}/following/{targetUid} {
      allow read: if isSignedIn();
      allow create, delete: if isSignedIn()
        && request.auth.uid == userId
        && userId != targetUid;
    }

    match /users/{userId}/followers/{followerUid} {
      allow read: if isSignedIn();
      allow create, delete: if isSignedIn()
        && request.auth.uid == followerUid
        && userId != followerUid;
    }

    match /users/{userId}/bookmarks/{postId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    match /labs/{labId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.piId == request.auth.uid
        && request.auth.uid in request.resource.data.memberIds;
      allow update, delete: if isSignedIn()
        && request.auth.uid == resource.data.piId;
    }

    match /labs/{labId}/followers/{followerId} {
      allow read: if isSignedIn();
      allow create, delete: if isSignedIn() && request.auth.uid == followerId;
    }

    match /lab_invites/{inviteId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.invitedBy == request.auth.uid
        && exists(/databases/$(database)/documents/labs/$(request.resource.data.labId))
        && get(/databases/$(database)/documents/labs/$(request.resource.data.labId)).data.piId == request.auth.uid;
      allow update, delete: if isSignedIn()
        && get(/databases/$(database)/documents/labs/$(resource.data.labId)).data.piId == request.auth.uid;
    }

    match /jobs/{jobId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.postedByUserId == request.auth.uid
        && request.resource.data.active == true
        && (
          (
            request.resource.data.labId != null
            && exists(/databases/$(database)/documents/labs/$(request.resource.data.labId))
            && get(/databases/$(database)/documents/labs/$(request.resource.data.labId)).data.piId == request.auth.uid
          )
          || request.resource.data.labId == null
        );
      allow update, delete: if isSignedIn() && (
        (
          resource.data.labId != null
          && exists(/databases/$(database)/documents/labs/$(resource.data.labId))
          && get(/databases/$(database)/documents/labs/$(resource.data.labId)).data.piId == request.auth.uid
        )
        || (
          resource.data.labId == null
          && resource.data.postedByUserId == request.auth.uid
        )
      );
    }

    match /coffee_chats/{chatId} {
      allow read: if isSignedIn() && (
        resource.data.fromUserId == request.auth.uid ||
        resource.data.toUserId == request.auth.uid
      );
      allow create: if isSignedIn()
        && request.resource.data.fromUserId == request.auth.uid
        && request.resource.data.toUserId != request.auth.uid
        && request.resource.data.status == 'pending'
        && request.resource.data.message is string
        && request.resource.data.message.size() <= 500;
      allow update: if isSignedIn()
        && resource.data.toUserId == request.auth.uid
        && resource.data.status == 'pending'
        && (
          request.resource.data.status == 'accepted' ||
          request.resource.data.status == 'declined'
        );
      allow delete: if false;
    }

    match /users/{userId}/saved_jobs/{jobId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    match /posts/{postId} {
      allow read: if canViewPost(postId);
      allow create: if isSignedIn()
        && request.auth.uid == request.resource.data.authorId;
      allow update: if isSignedIn() && (
        request.auth.uid == resource.data.authorId ||
        postEngagementOnly()
      );
      allow delete: if isSignedIn()
        && request.auth.uid == resource.data.authorId;
    }

    match /posts/{postId}/comments/{commentId} {
      allow read: if canViewPost(postId);
      allow create: if isSignedIn()
        && request.auth.uid == request.resource.data.authorId
        && canViewPost(postId);
      allow update, delete: if isSignedIn()
        && request.auth.uid == resource.data.authorId;
    }

    match /posts/{postId}/resonates/{resonatorId} {
      allow read: if canViewPost(postId);
      allow create: if isSignedIn()
        && request.auth.uid == resonatorId
        && canViewPost(postId);
      allow delete: if isSignedIn() && request.auth.uid == resonatorId;
    }

    match /feed/{userId}/items/{itemId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
      allow create: if isSignedIn() && (
        request.auth.uid == userId ||
        (
          request.auth.uid == request.resource.data.authorId
          && exists(/databases/$(database)/documents/users/$(userId))
          && request.auth.uid in get(/databases/$(database)/documents/users/$(userId)).data.following
        ) ||
        (
          request.auth.uid == request.resource.data.authorId
          && request.resource.data.sourceLabId != null
          && request.resource.data.postId != null
          && postExists(request.resource.data.postId)
          && postData(request.resource.data.postId).labId == request.resource.data.sourceLabId
          && (
            (
              postData(request.resource.data.postId).visibility == 'public'
              && exists(/databases/$(database)/documents/labs/$(request.resource.data.sourceLabId)/followers/$(userId))
            ) ||
            (
              postData(request.resource.data.postId).visibility == 'members_only'
              && userId in get(/databases/$(database)/documents/labs/$(request.resource.data.sourceLabId)).data.memberIds
              && request.auth.uid in get(/databases/$(database)/documents/labs/$(request.resource.data.sourceLabId)).data.memberIds
            )
          )
        )
      );
      allow update, delete: if false;
    }

    match /notifications/{userId}/items/{notifId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
      allow create: if isSignedIn()
        && request.resource.data.fromUserId == request.auth.uid
        && (
          (
            request.resource.data.type == 'resonate'
            && request.resource.data.postId != null
            && postExists(request.resource.data.postId)
            && userId == postData(request.resource.data.postId).authorId
          ) ||
          (
            request.resource.data.type == 'follow'
            && request.resource.data.targetUserId == userId
          ) ||
          (
            request.resource.data.type == 'lab_invite'
            && request.resource.data.targetUserId == userId
          )
        );
      allow update: if isSignedIn() && request.auth.uid == userId;
      allow delete: if isSignedIn() && request.auth.uid == userId;
    }

    match /research_logs/{logId} {
      allow read: if isSignedIn() && (
        resource.data.isPublic == true ||
        resource.data.userId == request.auth.uid
      );
      allow create: if isSignedIn()
        && request.auth.uid == request.resource.data.userId;
      allow update, delete: if isSignedIn()
        && request.auth.uid == resource.data.userId;
    }

    match /research_graph/{userId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && request.auth.uid == userId;
      allow delete: if false;
    }

    match /profile_visits/{visitedUid}/visitors/{visitorUid} {
      allow read: if isSignedIn() && request.auth.uid == visitedUid;
      allow create, update: if isSignedIn()
        && request.auth.uid == visitorUid
        && visitorUid != visitedUid;
      allow delete: if false;
    }

    match /papers/{paperId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.addedBy == request.auth.uid;
      allow update, delete: if isSignedIn()
        && resource.data.addedBy == request.auth.uid;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Profiles: any signed-in user can read; each user writes only their own doc.
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null && request.auth.uid == userId;
      allow delete: if false;
    }

    // Labs: directory readable for search/onboarding; create when you are the PI;
    // only the PI may update or delete the lab document.
    match /labs/{labId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.piId == request.auth.uid
        && request.auth.uid in request.resource.data.memberIds;
      allow update, delete: if request.auth != null
        && request.auth.uid == resource.data.piId;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}

# Copy to .env.local and fill in from Firebase console (Project settings).
# Never commit .env.local.
# Do not wrap values in quotes unless the value itself contains spaces.

REACT_APP_FIREBASE_API_KEY=
# Must be the Web API key from the same Firebase project (Project settings → General → Your apps).
REACT_APP_FIREBASE_AUTH_DOMAIN=
REACT_APP_FIREBASE_PROJECT_ID=
REACT_APP_FIREBASE_STORAGE_BUCKET=
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=
REACT_APP_FIREBASE_APP_ID=
